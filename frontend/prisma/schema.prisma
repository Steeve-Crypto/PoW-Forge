// This is your Prisma schema file for PoWForge backend.
// Run `npx prisma migrate dev --name init` after setup.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Change to "sqlite" for local development
  url      = env("DATABASE_URL")
}

model Deployment {
  id                String   @id @default(cuid())
  deployer          String
  collectionAddress String   @unique
  name              String
  symbol            String
  txHash            String?
  feeCollected      String
  timestamp         DateTime @default(now())
  
  @@index([deployer])
  @@index([collectionAddress])
}

model MintRequest {
  id          String   @id @default(cuid())
  requestId   String   @unique
  user        String
  nonce       String
  fulfilled   Boolean  @default(false)
  tokenId     String?
  rarityScore Int?
  timestamp   DateTime @default(now())
  
  @@index([user])
}

model NFT {
  id          String   @id @default(cuid())
  tokenId     String   @unique
  owner       String
  rarityScore Int
  collection  String?
  timestamp   DateTime @default(now())
}
