# PoWForge Frontend Environment Variables

# Contract Addresses (update after deployment)
NEXT_PUBLIC_POWNFT_ADDRESS=0x...

# Subgraph (after deploying with ./subgraph/deploy.sh)
NEXT_PUBLIC_SUBGRAPH_URL=https://api.studio.thegraph.com/query/your-id/powforge/version/latest

# Pinata for IPFS pinning (get free JWT at pinata.cloud)
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_here

# WalletConnect Project ID (get free at cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id
